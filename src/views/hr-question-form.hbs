<main class="hero-page">
  <section class="hero-card question-form-card">
    <p class="eyebrow">HR Console</p>
    <h1>{{formTitle}}</h1>
    <p class="subtitle">Pemetaan DISC tetap: A=D, B=I, C=S, D=C.</p>

    {{#if errorMessage}}
      <div class="alert">{{errorMessage}}</div>
    {{/if}}

    <form method="post" action="{{actionUrl}}" class="identity-form">
      <label>
        Urutan Soal
        <input type="number" min="1" name="order" value="{{values.order}}" required>
      </label>

      <label>
        Opsi A (Dominance)
        <input type="text" name="option_a" value="{{values.option_a}}" required>
      </label>

      <label>
        Opsi B (Influence)
        <input type="text" name="option_b" value="{{values.option_b}}" required>
      </label>

      <label>
        Opsi C (Steadiness)
        <input type="text" name="option_c" value="{{values.option_c}}" required>
      </label>

      <label>
        Opsi D (Conscientiousness)
        <input type="text" name="option_d" value="{{values.option_d}}" required>
      </label>

      <label class="check-inline">
        <input type="checkbox" name="is_active" value="1" {{#if values.is_active}}checked{{/if}}>
        Aktifkan soal ini
      </label>

      <div class="hr-actions">
        <button type="submit" class="btn-primary">Simpan</button>
        <a href="/hr/questions" class="btn-secondary">Batal</a>
      </div>
    </form>
  </section>
</main>
